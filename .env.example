# Stacks wallet mnemonic (24 words)
CLIENT_MNEMONIC="your twenty four word mnemonic phrase goes here"

# Network: mainnet or testnet
NETWORK=testnet

# x402 API base URL
API_URL=https://x402.biwas.xyz

# Pillar API
PILLAR_API_URL=https://api.pillar.fi
PILLAR_API_KEY=

# Hiro API Key (optional)
# Improves rate limits for Stacks blockchain queries
# Get your key at: https://platform.hiro.so/
HIRO_API_KEY=

# Sponsor Relay API Key (optional)
# Enables gasless transactions for ERC-8004 and sBTC
# Get your key at: https://x402-relay.aibtc.com
SPONSOR_API_KEY=

# Optional: override the editorial timezone used for the news bot schedule.
# The default tracks the aibtc.news Pacific-date filing window.
NEWS_BOT_TIMEZONE=America/Los_Angeles

# Optional: front-load the six daily filing slots into the opening window.
# Default: 5 0,1,2,3,4,5 * * *   (00:05 through 05:05 in NEWS_BOT_TIMEZONE)
NEWS_BOT_CRON=

# Optional JingSwap API key override for higher limits.
JINGSWAP_API_KEY=

# Groq API Key (FREE - get at console.groq.com, no credit card needed)
# Used for LLM synthesis of news signals
# Legacy: no longer required by the current Agent Trading news bot.
GROQ_API_KEY=

